#!/bin/bash
# adapter: Makefile <-> agent runtime. Roles: plan <goal> | build <id> | review | preflight
#
# RUNTIME=cli (default) | sdk
#   cli: ENGINE_CLI=claude (default) | pi | codex | gemini | opencode | custom
#        ENGINE_CLI_FLAGS appended verbatim (except custom)
#        custom: ENGINE_CLI_CUSTOM='mycli --flag {prompt}' — full cmdline template,
#          word-split on whitespace; a literal {prompt} token becomes ONE argv
#          element (never shell-interpolated: trust boundary); without the token
#          the prompt is piped on stdin.
#   sdk: node runtime-sdk.mjs (pi agentic-loop SDK, same contract)
# Every call injects prompts/system.md (caveman+ponytail build style):
#   pi/claude via --append-system-prompt; codex/gemini/opencode/custom have no
#   append mechanism -> system.md prepended to the prompt with a delimiter.
#
# Effort knobs: $B/effort.json — written by build.mk's TIER knob rule (deterministic jq), e.g.
#   {"tier":"prd","fanout":"5-8","review_depth":"full","model_hint":"large","thinking":"high"}
#   model_hint small/large → MODEL_SMALL/MODEL_LARGE env (unset → provider default)
# Optional hand-authored per-unit overrides may coexist in the same file:
#   {"default":"med",
#    "units":{"plan":"high","<component-id>":"low"},
#    "tiers":{"med":{"model":"provider/id","thinking":"medium"}}}
# thinking levels: off minimal low medium high xhigh (pi); mapped to --effort for claude.
set -euo pipefail
DIR=$(cd "$(dirname "$0")" && pwd)
B=${B:-build} SRC=${SRC:-src}
RUNTIME=${RUNTIME:-cli}
ENGINE_CLI=${ENGINE_CLI:-claude}

render() {  # render <prompt.md> — substitutes ${VARS} from environment
  python3 -c 'import sys,os
from string import Template
print(Template(open(sys.argv[1]).read()).safe_substitute(os.environ))' "$DIR/prompts/$1"
}

knob() {  # knob <field> <default> — goal-level knob from $B/effort.json
  jq -r --arg d "$2" ".$1 // \$d" "$B/effort.json" 2>/dev/null || echo "$2"
}

effort() {  # effort <unit> — sets MODEL/THINKING; goal-level knobs, units/tiers override
  MODEL='' THINKING=''
  local f="$B/effort.json" t
  [ "$1" = preflight ] && return 0  # preflight runs before effort.json exists
  [ -f "$f" ] || return 0
  THINKING=$(jq -r '.thinking // empty' "$f")
  case $(jq -r '.model_hint // empty' "$f") in
    small) MODEL=${MODEL_SMALL:-} ;;
    large) MODEL=${MODEL_LARGE:-} ;;
  esac
  t=$(jq -r --arg u "$1" '.units[$u] // .default // empty' "$f")
  [ -n "$t" ] || return 0
  MODEL=$(jq -r --arg t "$t" --arg m "$MODEL" '.tiers[$t].model // $m' "$f")
  THINKING=$(jq -r --arg t "$t" --arg k "$THINKING" '.tiers[$t].thinking // $k' "$f")
}

with_system() {  # CLI has no system-prompt append flag -> prepend system.md (honest fallback)
  printf '%s\n\n---\n\n%s' "$(cat "$DIR/prompts/system.md")" "$1"
}

claude_effort() {  # map pi thinking level -> claude --effort (off -> no flag)
  case $1 in
    minimal|low) echo low ;;
    medium)      echo medium ;;
    high)        echo high ;;
    xhigh)       echo xhigh ;;
    *)           echo '' ;;
  esac
}

run() {  # run <unit> <tools:yes|no> <prompt>
  local unit=$1 tools=$2 prompt=$3
  effort "$unit"
  if [ "$RUNTIME" = sdk ]; then
    ENGINE_MODEL=$MODEL ENGINE_THINKING=$THINKING \
    ENGINE_NO_TOOLS=$([ "$tools" = no ] && echo 1 || echo '') \
      node "$DIR/runtime-sdk.mjs" <<<"$prompt"
    return
  fi
  local cmd ce input=argv CODEX_OUT=''
  case $ENGINE_CLI in
    claude)
      cmd=(claude -p --append-system-prompt "$(cat "$DIR/prompts/system.md")")
      [ "$tools" = no ] && cmd+=(--tools "")
      [ -n "$MODEL" ] && cmd+=(--model "$MODEL")
      if [ -n "$THINKING" ]; then
        ce=$(claude_effort "$THINKING")
        [ -n "$ce" ] && cmd+=(--effort "$ce")
      fi
      input=stdin  # claude variadic flags (--tools) eat positional args
      ;;
    pi)
      cmd=(pi -p --no-context-files --no-skills --no-prompt-templates
           --no-extensions --append-system-prompt "$DIR/prompts/system.md")
      # PI_SESSION_DIR set -> keep sessions (token/cost accounting, evals/matrix); else ephemeral
      if [ -n "${PI_SESSION_DIR:-}" ]; then cmd+=(--session-dir "$PI_SESSION_DIR"); else cmd+=(--no-session); fi
      [ "$tools" = no ] && cmd+=(--no-tools)
      [ -n "$MODEL" ] && cmd+=(--model "$MODEL")
      [ -n "$THINKING" ] && cmd+=(--thinking "$THINKING")
      ;;
    codex)  # e2e UNVERIFIED: stdout is an event stream -> final msg via -o tmpfile
      prompt=$(with_system "$prompt")
      CODEX_OUT=$([ -n "${ENGINE_DRY:-}" ] && echo '<tmp>' || mktemp)
      cmd=(codex exec --skip-git-repo-check -o "$CODEX_OUT")
      [ "$tools" = yes ] && cmd+=(-s workspace-write)  # tools=no: default sandbox read-only
      [ -n "$MODEL" ] && cmd+=(-m "$MODEL")
      input=stdin  # no [PROMPT] arg + piped stdin -> reads prompt from stdin
      ;;
    gemini)  # UNVERIFIED-LOCALLY (not installed): piped stdin = non-interactive;
             # GEMINI_SYSTEM_MD REPLACES (not appends) core sys prompt -> prepend instead
      prompt=$(with_system "$prompt")
      cmd=(gemini)
      [ "$tools" = yes ] && cmd+=(--yolo)  # auto-approve tool actions; tools=no: no disable flag
      [ -n "$MODEL" ] && cmd+=(-m "$MODEL")
      input=stdin
      ;;
    opencode)  # UNVERIFIED-LOCALLY (not installed): no system-prompt flag -> prepend
      prompt=$(with_system "$prompt")
      cmd=(opencode run)
      [ -n "$MODEL" ] && cmd+=(-m "$MODEL")  # provider/model format
      ;;
    custom)
      [ -n "${ENGINE_CLI_CUSTOM:-}" ] || { echo "ENGINE_CLI=custom requires ENGINE_CLI_CUSTOM template" >&2; exit 1; }
      prompt=$(with_system "$prompt")  # unknown CLI -> honest fallback
      cmd=() input=stdin
      local tok
      # shellcheck disable=SC2086  # deliberate word split: user's own template
      for tok in $ENGINE_CLI_CUSTOM; do
        if [ "$tok" = '{prompt}' ]; then cmd+=("$prompt"); input=none; else cmd+=("$tok"); fi
      done
      ;;
    *) echo "unknown ENGINE_CLI: $ENGINE_CLI (claude|pi|codex|gemini|opencode|custom)" >&2; exit 1 ;;
  esac
  # shellcheck disable=SC2206  # deliberate word split: flag passthrough
  [ "$ENGINE_CLI" = custom ] || cmd+=(${ENGINE_CLI_FLAGS:-})  # custom template IS the full cmdline
  if [ -n "${ENGINE_DRY:-}" ]; then  # argv role: print rendered invocation, no agent call
    local sys a; sys=$(cat "$DIR/prompts/system.md")
    printf 'argv:'; for a in "${cmd[@]}"; do a=${a//"$sys"/<system.md>}; printf ' %q' "${a//"$DIR"/<engine>}"; done; echo
    case $input in
      stdin) printf 'stdin: %q\n' "${prompt//"$sys"/<system.md>}" ;;
      argv)  printf 'argv+: %q\n' "${prompt//"$sys"/<system.md>}" ;;
      none)  echo 'stdin: (none — {prompt} in template)' ;;
    esac
    return
  fi
  case $input in
    stdin)
      if [ -n "$CODEX_OUT" ]; then
        "${cmd[@]}" <<<"$prompt" >&2  # events -> stderr; clean final message -> stdout
        cat "$CODEX_OUT"; rm -f "$CODEX_OUT"
      else
        "${cmd[@]}" <<<"$prompt"
      fi ;;
    argv) "${cmd[@]}" "$prompt" ;;
    none) "${cmd[@]}" ;;
  esac
}

role=$1; shift
case $role in
  argv)  # dry: render invocation for current ENGINE_CLI, no agent call (selfcheck-argv.sh)
    ENGINE_DRY=1 run argv "${1:-no}" "${2:-PROMPT}"
    ;;
  preflight)  # cheap auth/echo probe: one tool-less call, exact-token contract
    out=$(run preflight no 'Reply with exactly the single word: PONG' 2>&1) || { echo "$out"; exit 1; }
    case $out in *PONG*) exit 0 ;; *) echo "unexpected agent reply: ${out:0:200}"; exit 1 ;; esac
    ;;
  plan)
    export GOAL_TEXT="$(cat "$1")" FANOUT="$(knob fanout "3-5")"
    # depth-conditional composite permission — optimization only; the jq template
    # in build.mk (AT_CAP) is the enforcement
    if [ "${AGENTMAKE_DEPTH:-0}" -lt "${AGENTMAKE_MAXDEPTH:-3}" ]; then
      export COMPOSITE_RULES='A component too large for one focused build session may set "kind":"composite" with "sub_goal": a self-contained goal spec (markdown, own acceptance criteria) for recursive decomposition. Use sparingly — most components are leaves.'
    else
      export COMPOSITE_RULES='Every component MUST be a leaf: omit "kind" or set "kind":"leaf". Composite is forbidden at this depth.'
    fi
    run plan no "$(render plan.md)" | sed '/^```/d'
    ;;
  build)
    id=$1
    export ID="$id" B SRC \
      DESC="$(jq -r --arg id "$id" '.components[] | select(.id==$id) | .desc' "$B/plan.json")" \
      GOAL_TEXT="$(cat "${GOAL:-goal.md}")" \
      SIBLINGS="$(ls "$SRC" 2>/dev/null | tr '\n' ' ' || echo none)"
    run "$id" yes "$(render build.md)"
    ;;
  review)
    case $(knob review_depth standard) in
      smoke) RUBRIC="Smoke check only: run each $SRC/*/check.sh; verdict from exit codes, skip code inspection and evals." ;;
      full)  RUBRIC="Full review: inspect all code, run each $SRC/*/check.sh, verify every acceptance criterion and edge case from the goal. Evals mandatory: run visual/TUI evals where applicable; missing or failing evals = FAIL." ;;
      *)     RUBRIC="Inspect code, run each $SRC/*/check.sh." ;;
    esac
    export GOAL_FILE="${GOAL:-goal.md}" SRC RUBRIC
    run review yes "$(render review.md)"
    ;;
  *) echo "unknown role: $role" >&2; exit 1 ;;
esac
